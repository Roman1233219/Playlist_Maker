<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnPrimary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Кнопка назад -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/toolbar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/strel"
                    android:drawablePadding="8dp"
                    android:drawableTint="?android:attr/textColorPrimary"
                    android:minHeight="56dp"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- ТОТ САМЫЙ КОНТЕЙНЕР ДЛЯ ОБЛОЖКИ (спринт 18) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/album_cover"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginStart="46dp"
                    android:layout_marginTop="26dp"
                    android:layout_marginEnd="46dp"
                    android:background="@android:color/transparent"
                    android:clipToOutline="true"
                    android:contentDescription="@string/album_cover_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/track_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/ys_display_medium"
                    android:textAlignment="viewStart"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toEndOf="@id/album_cover"
                    app:layout_constraintStart_toStartOf="@id/album_cover"
                    app:layout_constraintTop_toBottomOf="@id/album_cover"
                    tools:text="Название трека" />

                <TextView
                    android:id="@+id/artist_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/ys_display_medium"
                    android:textAlignment="viewStart"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@id/album_cover"
                    app:layout_constraintStart_toStartOf="@id/album_cover"
                    app:layout_constraintTop_toBottomOf="@id/track_name"
                    tools:text="Исполнитель" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Контейнер для кнопок управления -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="30dp">

                <ImageButton
                    android:id="@+id/btn_add"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_marginStart="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/add_to_playlist_description"
                    android:src="@drawable/plus"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.51" />

                <ImageButton
                    android:id="@+id/btn_play_pause"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="?attr/colorOnPrimary"
                    android:contentDescription="@string/play_pause_description"
                    android:src="@drawable/play"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/btn_favorite"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_marginEnd="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/add_to_favorites_description"
                    android:src="@drawable/izbran"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.51" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Таймер -->
            <TextView
                android:id="@+id/timer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/ys_display_medium"
                android:textAlignment="center"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:text="00:00" />

            <!-- Информация о треке -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:id="@+id/duration_container"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="124dp"
                        android:layout_height="wrap_content"
                        android:text="@string/duration"
                        android:textColor="?attr/colorSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular"/>
                    <TextView
                        android:id="@+id/duration_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:lines="1"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular"
                        tools:text="3:45" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/album_container"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="124dp"
                        android:layout_height="wrap_content"
                        android:text="@string/album"
                        android:textColor="?attr/colorSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular" />
                    <TextView
                        android:id="@+id/album_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:lines="1"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular"
                        tools:text="Название альбома" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/year_container"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="124dp"
                        android:layout_height="wrap_content"
                        android:text="@string/year"
                        android:textColor="?attr/colorSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular" />
                    <TextView
                        android:id="@+id/year_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:lines="1"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular"
                        tools:text="2023" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/genre_container"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="124dp"
                        android:layout_height="wrap_content"
                        android:text="@string/genre"
                        android:textColor="?attr/colorSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular" />
                    <TextView
                        android:id="@+id/genre_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:lines="1"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular"
                        tools:text="Pop" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/country_container"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="124dp"
                        android:layout_height="wrap_content"
                        android:text="@string/country"
                        android:textColor="?attr/colorSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular" />
                    <TextView
                        android:id="@+id/country_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:lines="1"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:fontFamily="@font/ys_display_regular"
                        tools:text="USA" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/standard_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="500dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#AEAFB4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/ys_display_medium"
            android:text="@string/add_to_playlist"
            android:textColor="?attr/android:textColorPrimary"
            android:textSize="19sp" />

        <Button
            android:id="@+id/btn_new_playlist"
            style="@style/SettingsButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"
            android:text="@string/new_playlist" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlist_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
