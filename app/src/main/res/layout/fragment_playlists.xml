<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnPrimary"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <Button
        android:id="@+id/new_playlist_button"
        style="@style/SettingsButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="45dp"
        android:text="@string/new_playlist"
        android:textAllCaps="false"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/empty_playlists_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/placeholder_no_results"
        android:contentDescription="@string/empty_playlists" />

    <TextView
        android:id="@+id/empty_playlists_text"
        android:layout_width="wrap_content"
        android:layout_height="46dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/ys_display_medium"
        android:gravity="center"
        android:includeFontPadding="false"
        android:lineHeight="19dp"
        android:text="@string/empty_playlists"
        android:textColor="?attr/android:textColorPrimary"
        android:textSize="19sp" />
</LinearLayout>
